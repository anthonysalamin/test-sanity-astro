---
import Layout from '../../layouts/Layout.astro'
import {getTokens} from '../../lib/sanity'

export async function getStaticPaths() {
  const tokens = await getTokens()
  return tokens.map((token) => ({
    params: {slug: token.slug.current},
    props: {token},
  }))
}

const {token} = Astro.props
---

{/* Mirrors webflow/detail_tokens.html, whose body is empty (no elements were
    added to the template in the Designer). Add bindings here when the Webflow
    template gains content. */}
<Layout title={token.name} />
